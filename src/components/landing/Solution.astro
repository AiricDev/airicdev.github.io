---
import SectionHeader from './SectionHeader.astro';
import { features } from '@/data/landing';
---

<section class="border-b border-border">
  <div class="mx-auto max-w-6xl px-6 py-24">
    <SectionHeader index="02" eyebrow="the solution" title="Airic makes methodology executable." />
    <div class="mt-12 grid gap-px overflow-hidden rounded-lg border border-border bg-border md:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f, i) => (
          <div class="group relative flex flex-col gap-3 bg-card p-6 transition-colors hover:bg-secondary">
            <div class="flex items-center justify-between">
              <span class="font-mono text-[11px] text-muted-foreground">
                0{i + 1}
              </span>
              <span class="font-mono text-[11px] text-accent opacity-0 transition-opacity group-hover:opacity-100">
                →
              </span>
            </div>
            <h3 class="text-lg font-semibold tracking-tight text-foreground">{f.title}</h3>
            <p class="text-sm leading-relaxed text-muted-foreground">{f.desc}</p>
            <div class="mt-auto pt-3">
              <code class="inline-block rounded border border-border bg-background px-2 py-1 font-mono text-[11px] text-foreground/80">
                {f.snip}
              </code>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
