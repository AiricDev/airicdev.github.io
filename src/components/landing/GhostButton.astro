---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<a
  href={href}
  class="inline-flex h-10 items-center justify-center rounded-md border border-border-strong bg-transparent px-4 font-mono text-sm font-medium text-foreground transition-colors hover:bg-secondary"
>
  <slot />
</a>
