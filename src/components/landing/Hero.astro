---
import PrimaryButton from './PrimaryButton.astro';
---

<section id="top" class="border-b border-border">
  <div class="mx-auto grid max-w-6xl gap-12 px-6 py-16 sm:py-24 lg:grid-cols-[1.15fr_1fr] lg:gap-16 lg:py-28">
    <div class="flex flex-col justify-center">
      <div class="mb-6 inline-flex self-start items-center gap-2 rounded-full border border-border bg-card px-3 py-1">
        <span class="h-1.5 w-1.5 rounded-full bg-foreground"></span>
        <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-muted-foreground">Coming soon · Open source</span>
      </div>
      <h1 class="text-5xl font-semibold leading-[1.02] tracking-tight text-foreground sm:text-6xl lg:text-7xl">A trainable<br />agent.</h1>
      <p class="mt-6 max-w-xl text-xl font-medium text-foreground sm:text-2xl">Turn any methodology into a working agent.</p>
      <p class="mt-4 max-w-xl text-base leading-relaxed text-muted-foreground sm:text-lg">Airic turns your methods into an agent operating model, then improves that model through real work, reflection, and review.</p>
      <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
        <PrimaryButton href="#waitlist">Join the waitlist</PrimaryButton>
        <a href="#how-it-learns" class="group inline-flex items-center gap-1.5 text-sm font-medium text-foreground">See how Airic learns <span class="transition-transform group-hover:translate-y-0.5">↓</span></a>
      </div>
    </div>
    <div class="rounded-lg border border-border bg-card p-6 sm:p-8">
      <div class="mb-3 flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-foreground"></span><span class="font-mono text-[10px] uppercase tracking-[0.14em] text-muted-foreground">01 · Onboard with knowledge</span></div>
      <div class="grid grid-cols-3 gap-2 sm:gap-3">
        {['A methodology book', 'Team handbook', 'Project playbook'].map((label) => <div class="rounded-md border border-border bg-background p-2.5 sm:p-3"><div class="mb-1.5 flex gap-0.5"><span class="h-1 w-4 rounded-full bg-muted-foreground/40"></span><span class="h-1 w-2 rounded-full bg-muted-foreground/40"></span></div><p class="font-mono text-[10px] leading-tight text-foreground">{label}</p></div>)}
      </div>
      <div class="my-3 text-center font-mono text-muted-foreground">↓</div>
      <div class="mx-auto flex w-fit items-center gap-3 rounded-md border border-foreground bg-foreground px-5 py-2.5 text-background"><span class="h-2 w-2 rounded-sm bg-background"></span><span class="font-mono text-sm font-semibold tracking-wide">AIRIC</span></div>
      <div class="my-3 text-center font-mono text-muted-foreground">↓</div>
      <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">{['Procedures', 'Standards', 'Checklists', 'Decision boundaries'].map((label) => <div class="rounded-md border border-border bg-background px-2.5 py-2"><p class="font-mono text-[10px] leading-tight text-foreground">{label}</p></div>)}</div>
      <div class="mb-3 mt-8 flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-foreground"></span><span class="font-mono text-[10px] uppercase tracking-[0.14em] text-muted-foreground">02 · Train through experience</span></div>
      <div class="space-y-2">{['Real work', 'Reflection', 'Reviewed update', 'Better next task'].map((label, index) => <div class="flex items-center gap-3"><span class="font-mono text-[10px] text-muted-foreground">{String(index + 1).padStart(2, '0')}</span><div class="flex-1 rounded-md border border-border bg-background px-3 py-2"><p class="font-mono text-xs text-foreground">{label}</p></div>{index < 3 && <span class="font-mono text-xs text-muted-foreground">↓</span>}</div>)}</div>
    </div>
  </div>
</section>
