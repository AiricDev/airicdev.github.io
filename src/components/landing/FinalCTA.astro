<section id="waitlist" class="bg-foreground text-background">
  <div class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-semibold leading-tight tracking-tight sm:text-4xl lg:text-5xl">Onboard Airic with your methods.<br /><span class="text-background/60">Train it through real work.</span></h2>
      <p class="mt-5 text-base text-background/70 sm:text-lg">Join the waitlist for early access to the first release.</p>
      <form id="waitlist-form" class="mx-auto mt-10 flex w-full max-w-md flex-col gap-2 sm:flex-row">
        <label for="email" class="sr-only">Email address</label>
        <input id="email" name="email" type="email" required maxlength="255" autocomplete="email" placeholder="you@domain.com" class="flex-1 rounded-md border border-background/20 bg-background/5 px-4 py-3 text-sm text-background placeholder:text-background/40 focus:border-background/60 focus:outline-none" />
        <label class="sr-only" aria-hidden="true">Website <input name="website" tabindex="-1" autocomplete="off" /></label>
        <button type="submit" class="rounded-md bg-background px-5 py-3 text-sm font-medium text-foreground transition-opacity hover:opacity-90">Join the waitlist</button>
      </form>
      <p id="waitlist-status" class="mt-3 min-h-5 text-sm text-background/70" aria-live="polite"></p>
      <p class="mt-3 font-mono text-[11px] text-background/50">Open source. No spam. Only launch updates and early access.</p>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>('#waitlist-form');
  const status = document.querySelector<HTMLParagraphElement>('#waitlist-status');
  const button = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form.reportValidity() || !status || !button) return;

    const formData = new FormData(form);
    button.disabled = true;
    button.textContent = 'Joining…';
    status.textContent = '';

    try {
      const response = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: formData.get('email'), website: formData.get('website') }),
      });
      const result = await response.json() as { ok?: boolean; alreadyJoined?: boolean; error?: string };
      if (!response.ok || !result.ok) throw new Error(result.error || 'Unable to join the waitlist.');

      form.reset();
      status.textContent = result.alreadyJoined ? 'You are already on the waitlist.' : "You're on the list — thank you.";
    } catch (error) {
      status.textContent = error instanceof Error ? error.message : 'Unable to join the waitlist. Please try again.';
    } finally {
      button.disabled = false;
      button.textContent = 'Join the waitlist';
    }
  });
</script>
