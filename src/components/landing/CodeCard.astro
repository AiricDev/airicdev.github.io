---
interface Props {
  title?: string;
  class?: string;
}

const { title, class: className = '' } = Astro.props;
---

<div
  class={`overflow-hidden rounded-lg border border-border bg-card shadow-[0_1px_0_0_var(--color-border)] ${className}`}
>
  {
    title && (
      <div class="flex items-center justify-between border-b border-border bg-secondary px-4 py-2">
        <span class="font-mono text-xs text-muted-foreground">{title}</span>
        <div class="flex gap-1.5">
          <span class="h-2 w-2 rounded-full bg-border-strong" />
          <span class="h-2 w-2 rounded-full bg-border-strong" />
          <span class="h-2 w-2 rounded-full bg-border-strong" />
        </div>
      </div>
    )
  }
  <div class="p-5 font-mono text-[13px] leading-relaxed">
    <slot />
  </div>
</div>
