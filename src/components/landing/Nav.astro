---
import Logo from '@/components/Logo.astro';
import { siteMeta } from '@/data/landing';
---

<header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur">
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-6">
    <Logo showBadge />
    <nav class="flex items-center gap-1">
      <a
        href="#packsmith"
        class="hidden rounded-md px-3 py-1.5 font-mono text-xs text-muted-foreground transition-colors hover:text-foreground sm:inline"
      >
        packsmith
      </a>
      <a
        href="#demo"
        class="hidden rounded-md px-3 py-1.5 font-mono text-xs text-muted-foreground transition-colors hover:text-foreground sm:inline"
      >
        demo
      </a>
      <a
        href="/docs/"
        class="hidden rounded-md px-3 py-1.5 font-mono text-xs text-muted-foreground transition-colors hover:text-foreground sm:inline"
      >
        docs
      </a>
      <a
        href={siteMeta.githubUrl}
        class="ml-2 inline-flex h-8 items-center rounded-md border border-border-strong px-3 font-mono text-xs text-foreground transition-colors hover:bg-secondary"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub ↗
      </a>
    </nav>
  </div>
</header>
