---
import Logo from '@/components/Logo.astro';
---

<header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <Logo />
    <nav class="flex items-center gap-1 sm:gap-2">
      <a href="#methodology" class="hidden rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground sm:inline-block">How it works</a>
      <a href="#how-it-learns" class="hidden rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground sm:inline-block">Research</a>
      <a href="#waitlist" class="ml-2 inline-flex items-center rounded-md bg-foreground px-3.5 py-2 text-sm font-medium text-background transition-opacity hover:opacity-90">Join the waitlist</a>
    </nav>
  </div>
</header>
